# Database connection (AWS RDS)
DB_HOST=mapvibe-db-mvp.xxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mapvibe
DB_USER=mapvibe_admin
DB_PASSWORD=your_password_here

# AWS (optional for local - uses default credentials)
AWS_REGION=us-east-1
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:xxxxx:secret:mapvibe/db-credentials-mvp

# Environment
NODE_ENV=development
