{
  "name": "mapvibe",
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "deploy:infra": "turbo run deploy --filter=infrastructure",
    "deploy:web": "turbo run deploy --filter=web",
    "deploy:lambda": "turbo run deploy --filter=api-functions"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "eslint": "^9.39.1",
    "kysely-codegen": "^0.19.0",
    "kysely-migration-cli": "^0.4.2",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.11.1",
    "bun": ">=1.3.2"
  },
  "packageManager": "bun@1.3.2"
}
