{
  "name": "@mapvibe/api-functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=node",
    "dev": "bun run --watch src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mapvibe/constants": "workspace:*",
    "@mapvibe/database": "workspace:*",
    "@mapvibe/types": "workspace:*",
    "@mapvibe/utils": "workspace:*",
    "kysely": "^0.28.8",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.158"
  }
}
