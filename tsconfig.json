{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@mapvibe/types": ["./packages/types/src"],
      "@mapvibe/utils": ["./packages/utils/src"],
      "@mapvibe/constants": ["./packages/constants/src"],
      "@mapvibe/ui-components": ["./packages/ui-components/src"],
      "@mapvibe/database": ["./packages/database"],
      "@mapvibe/api-functions": ["./packages/api-functions/src"]
    },
    "noEmit": true,
    "allowJs": true,
    "checkJs": false
  },
  "exclude": ["node_modules", "dist", "build", ".turbo", "coverage"]
}
